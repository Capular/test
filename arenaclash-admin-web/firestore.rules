rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow any logged-in user to READ everything. Write is disable for safety.
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // --- Helper Functions ---
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user has 'admin' role in their user profile
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Check if user has 'moderator' role
    function isModerator() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator';
    }

    // Check if incoming data has specific fields unchanged
    function notUpdating(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // DEBUG: Allow any logged in user to read profiles (needed for leaderboards anyway?)
      allow read: if isAuthenticated(); 
      allow create, delete: if isAdmin();
      
      allow update: if isAdmin() || (
        isOwner(userId) && 
        notUpdating(['walletBalance', 'role', 'isBanned', 'isPro', 'createdAt'])
      );
    }

    // 2. Tournaments Collection
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin() || isModerator();
    }

    // 3. Templates Collection
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin() || isModerator();
    }

    // 4. Games Collection
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Notifications Collection
    match /notifications/{notificationId} {
      // DEBUG: Relaxed to auth only
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
        notUpdating(['userId', 'type', 'message', 'createdAt']);
      allow delete: if isAdmin();
    }

    // 6. Transactions Collection
    match /transactions/{transactionId} {
      // DEBUG: Relaxed to auth only
      allow read: if isAuthenticated();
      // STRICTLY ADMIN WRITE
      allow write: if isAdmin();
    }

    // 7. Queued Registrations
    match /queued_registrations/{queueId} {
      allow read: if isAuthenticated(); // User checks their own queue status
      allow create: if isAuthenticated(); // Server function normally handles this, but client might need read
      allow delete: if isAdmin(); // Only admin/server removes from queue
    }


    // 7. Players / Registrations (Collection Group)
    match /{path=**}/players/{playerId} {
      // Public read so checking active status works
      allow read: if true; 
      
      // Joining a tournament
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can leave/update status
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
